{
  "name": "crm-backend",
  "version": "1.0.0",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "mysql -u %DB_USER% -p%DB_PASSWORD% < migrations/schema.sql",
    "migrate:update": "mysql -u %DB_USER% -p%DB_PASSWORD% < migrations/update.sql",
    "migrate:all": "npm run migrate && npm run migrate:update"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
